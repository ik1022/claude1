# Doxyfile for libemb project
# Auto-generated from Doxyfile.in by CMake

PROJECT_NAME           = "libemb"
PROJECT_NUMBER         = "@PROJECT_VERSION@"
PROJECT_BRIEF          = "Modern embedded C++ firmware library for MCU-based systems"

INPUT                  = "@CMAKE_CURRENT_SOURCE_DIR@/include" \
                         "@CMAKE_CURRENT_SOURCE_DIR@/src"
INPUT_ENCODING         = UTF-8
FILE_PATTERNS          = *.h *.hpp *.cpp *.md
RECURSIVE              = YES
EXCLUDE_PATTERNS       = "*test*" "*Test*" "*mock*"

OUTPUT_DIRECTORY       = "@CMAKE_CURRENT_BINARY_DIR@/docs"
HTML_OUTPUT            = html
GENERATE_HTML          = YES
GENERATE_LATEX         = NO
GENERATE_MAN           = NO
GENERATE_XML           = NO

# Theme configuration
HTML_THEME             = doxygen
HTML_THEME_PATH        =
MATHJAX_RELPATH        = https://cdn.mathjax.org/mathjax/latest
MATHJAX_CODEFILE       =

# HTML customization
HTML_HEADER            =
HTML_FOOTER            =
HTML_STYLESHEET        =
HTML_EXTRA_STYLESHEET  =

# Docset configuration
GENERATE_DOCSET        = NO
DOCSET_FEEDNAME        = "libemb Documentation"
DOCSET_BUNDLE_ID       = com.libemb.docs
DOCSET_PUBLISHER_ID    = com.libemb
DOCSET_PUBLISHER_NAME  = libemb

# Search engine configuration
SEARCHENGINE           = YES
SERVER_BASED_SEARCH    = NO

# Documentation settings
EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = NO
EXTRACT_PACKAGE        = NO
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = YES
EXTRACT_ANON_NSPACES   = NO

# Source code links
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
STRIP_CODE_COMMENTS    = NO
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES
REFERENCES_LINK_SOURCE = YES

# Alphabetical indexing
ALPHABETICAL_INDEX     = YES
COLS_IN_ALPHA_INDEX    = 5

# Processing options
FORCE_LOCAL_RANGES     = NO
CASE_SENSE_FILENAMES   = YES
HIDE_SCOPE_NAMES       = NO
HIDE_COMPOUND_MEMBERS  = NO

# Warnings
WARN_NO_PARAMDOC       = YES
WARN_AS_ERROR          = YES

# Grouping
GROUP_NESTED_CLASSES   = YES
SORT_GROUP_NAMES       = YES
SORT_MEMBERS_CTORS_1ST = NO

# Formatting
BRIEF_MEMBER_DESC      = YES
REPEAT_BRIEF           = YES
ALWAYS_DETAILED_SEC    = NO
INLINE_INHERITED_MEMB  = NO
FULL_PATH_NAMES        = NO
SHORT_NAMES            = NO
JAVADOC_AUTOBRIEF      = YES
MARKDOWN_SUPPORT       = YES
TOC_INCLUDE_HEADINGS   = 0
AUTOLINK_SUPPORT       = YES
BUILTIN_STL_SUPPORT    = YES
IDL_PROPERTY_SUPPORT   = YES
DISTRIBUTE_GROUP_DOC   = NO

# Special formatting
TYPEDEF_HIDES_STRUCT   = YES
SYMBOL_CACHE_SIZE      = 0
CLANG_ASSISTED_PARSING = NO
CLANG_ADD_INC_PATHS    = YES

# C++ specifics
CPP_CLI_SUPPORT        = NO
SET_PROJECT_NAME       = YES
DOXYGEN_INTERNAL       = NO

# Namespace documentation
OPTIMIZE_OUTPUT_FOR_C  = NO
OPTIMIZE_OUTPUT_JAVA   = NO
OPTIMIZE_FOR_FORTRAN   = NO
OPTIMIZE_OUTPUT_VHDL   = NO

# Alias definitions
ALIASES                =
ALIASES               += "safe_fix=\warning This fix can be automatically applied by Clang-Tidy"
ALIASES               += "manual_fix=\note This fix requires manual review"
ALIASES               += "no_fix=\attention This should not be automatically fixed"

# Image paths
IMAGE_PATH             = @CMAKE_CURRENT_SOURCE_DIR@/docs/images

# Sections order
TOC_EXPAND             = YES
ENUM_VALUES_PER_LINE   = 4

# Inheritance and collaboration diagrams
CLASS_DIAGRAMS         = YES
MSCGEN_PATH            =
DIA_PATH               =
HIDE_UNDOC_RELATIONS   = YES
HAVE_DOT               = NO
DOT_FONTNAME           = Helvetica
DOT_FONTSIZE           = 10
DOT_GRAPH_MAX_NODES    = 50
MAX_DOT_GRAPH_DEPTH    = 0
DOT_TRANSPARENT        = NO
DOT_MULTIPLE_TARGETS   = NO
GENERATE_LEGEND        = YES
DOT_CLEANUP            = YES

# Example paths
EXAMPLE_PATH           = @CMAKE_CURRENT_SOURCE_DIR@/examples
EXAMPLE_PATTERNS       = *
EXAMPLE_RECURSIVE      = YES

# Perl path
PERL_PATH              = /usr/bin/perl

# Configuration options related to LaTeX
LATEX_OUTPUT           = latex
LATEX_CMD_NAME         = latex
MAKEINDEX_CMD_NAME     = makeindex
COMPACT_LATEX          = NO
LATEX_HYPERLINK        = YES
PDF_HYPERLINKS         = YES
USE_PDFLATEX           = YES
LATEX_BATCHMODE        = NO
LATEX_HIDE_INDICES     = NO
LATEX_SOURCE_CODE      = YES
LATEX_BIB_STYLE        = plain

# Man page generation
MAN_OUTPUT             = man
MAN_EXTENSION          = .3
MAN_LINKS              = NO

# RTF output
GENERATE_RTF           = NO
RTF_OUTPUT             = rtf
COMPACT_RTF            = NO
RTF_HYPERLINKS         = NO
RTF_STYLESHEET_FILE    =

# Other outputs
GENERATE_DOCBOOK       = NO
DOCBOOK_OUTPUT         = docbook

# Miscellaneous
QUIET                  = NO
WARNINGS               = YES
QUIET_IF_WARNINGS      = NO
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_LAGS       = NO
WARN_FORMAT            = "$file:$line: $text"
WARN_LOGFILE           =

# Input filter
INPUT_FILTER           =
FILTER_PATTERNS        =
FILTER_SOURCE_FILES    = NO
FILTER_SOURCE_PATTERNS =

# Parsing
SKIP_FUNCTION_MACROS   = YES
ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = NO
EXPAND_ONLY_PREDEF     = NO
SEARCH_INCLUDES        = YES
INCLUDE_PATH           =
INCLUDE_FILE_PATTERNS  = *.h
PREDEFINED             =
EXPAND_AS_DEFINED      =
SKIP_FUNCTION_MACROS   = YES

# Tag files for linking external documentation
TAGFILES               =
GENERATE_TAGFILE       = @CMAKE_CURRENT_BINARY_DIR@/docs/libemb.tag
ALLEXTERNALS           = NO
EXTERNAL_GROUPS        = YES
PERL_PATH              = /usr/bin/perl

# Site-specific configuration
CITE_BIB_FILES         =

# Version control
USE_HTAGS              = NO

# Minimal configuration
MIN_LEVELS             = 1
